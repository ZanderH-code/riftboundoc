---
import BaseLayout from "../../layouts/BaseLayout.astro";
const runtimeScripts = ["page-list-page.js"];
---
<BaseLayout title="Pages - riftboundoc" runtimeScripts={runtimeScripts}>
  <main class="container">
    <h1>Community Pages</h1>
    <p class="muted">Browse structured rules and guides in web-native format.</p>
    <div id="page-list" class="list"></div>
  </main>
  <script is:inline>
    window.site.navActive();
    window.site.initPageList();
  </script>
</BaseLayout>

